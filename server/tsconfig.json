{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"outDir": "./dist",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"strict": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"ignoreDeprecations": "6.0"
	},
	"include": ["src/**/*.ts", "prisma.config.ts", "prisma/**/*.ts"],
	"exclude": ["dist"]
}